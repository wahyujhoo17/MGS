generator client {
  provider = "prisma-client-js"
}

generator nextAdmin {
  provider = "next-admin-generator-prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Category {
  id        String    @id @default(cuid())
  name      String
  slug      String    @unique
  products  Product[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Product {
  id                String   @id @default(cuid())
  slug              String   @unique
  name              String
  description       String
  variants          String[]
  weight            String
  priceRetail       Int
  priceWholesale    Int
  minOrderWholesale Int
  isSelfProduced    Boolean  @default(true)
  imageUrl          String?
  
  categoryId        String
  category          Category @relation(fields: [categoryId], references: [id])
  
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model Admin {
  id        String   @id @default(cuid())
  username  String   @unique
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

